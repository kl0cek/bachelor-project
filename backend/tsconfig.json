{
  // Visit https://aka.ms/tsconfig to read more about this file
  "compilerOptions": {
    "target": "es2022",
    "module": "commonJS",
    "rootDir": "./src",
    "outDir": "prod",
    "types": ["node"],
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "useDefineForClassFields": false,
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules"]
}
